    "@blocknote/xl-multi-column": "^0.47.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.12.0",
