# ---------------------------------------------------------------------------
# DataC Calendar module — environment template.
# Copy to `.env` and fill in. `.env*` is gitignored.
# ---------------------------------------------------------------------------

# --- Database (SQLite) -----------------------------------------------------
# Prisma connection string. Local SQLite — a single file, no server/daemon.
# Use an ABSOLUTE path so the CLI, the app, and the installed daemon all open
# the same file regardless of working directory. Back up by copying the file.
DATABASE_URL="file:/absolute/path/to/.datac/datac.db"

# --- Auth (single-user token) ----------------------------------------------
# Secret used to sign JWTs. Generate one: `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-secret
# How long an issued access token stays valid.
JWT_EXPIRES_IN=30d

# Owner account, seeded on first `npm run db:seed` (or first server boot).
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-strong-password
OWNER_NAME=Owner

# --- Firebase Cloud Messaging ----------------------------------------------
# Leave BOTH blank to keep push in stub mode (reminders are computed & logged
# but not delivered). Provide a service account to activate real FCM delivery:
#   FCM_SERVICE_ACCOUNT_PATH — path to the service-account JSON file, OR
#   FCM_SERVICE_ACCOUNT      — the same JSON inlined on one line.
# Create it in Firebase Console → Project settings → Service accounts →
# "Generate new private key". FCM_PROJECT_ID is optional (read from the JSON).
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT=
FCM_PROJECT_ID=

# --- Server ----------------------------------------------------------------
PORT=4321
# Comma-separated origins allowed to call the API (web app + mobile dev).
# Leave blank to allow same-origin only.
ALLOWED_ORIGINS=
LOG_LEVEL=info

# --- Reminder scheduler -----------------------------------------------------
# The self-hosted server runs the reminder scheduler in-process every minute.
# Set to 1 to disable it (e.g. on a cloud deploy where an external cron calls
# POST /api/calendar/scheduler/tick instead).
DISABLE_IN_PROCESS_SCHEDULER=
# Shared secret so an external cron can authorize the tick endpoint without a
# user login: send it as the X-Scheduler-Secret header. Leave blank to require
# a normal user session.
SCHEDULER_SECRET=
